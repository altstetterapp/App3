run = "npm install && npm run build && node server/index.js"
language = "nodejs"
modules = ["nodejs-20"]

[env]
NODE_ENV = "production"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "node server/index.js"]
build = ["sh", "-c", "npm install --include=dev && npm run build"]
deploymentTarget = "autoscale"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --include=dev && npm run build && PORT=5000 node server/index.js"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
